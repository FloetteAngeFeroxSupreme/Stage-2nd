def calculatrice(a,b,op):
    if op == "+":
        print(a+b)
    elif op == "-":
        print(a-b)
    elif op == "*":
        print(a*b)
    elif op == "/":
        if b==0:
            print("impossible")
        else:
            print(a/b)
    else:
        print("opérateur invalide")
calculatrice(int(input("entrez un nombre: ")),int(input("entrez un nombre: ")),input("entrez un opérateur: "))